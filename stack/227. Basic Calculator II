class Solution:
    def calculate(self, s: str) -> int:

        stack = []
        num = 0
        sign = '+'

        for i, ch in enumerate(s):

            # Build multi-digit number
            if ch.isdigit():
                num = num * 10 + int(ch)

            # Operator or end of string
            if (not ch.isdigit() and ch != " ") or i == len(s) - 1:

                if sign == '+':
                    stack.append(num)

                elif sign == '-':
                    stack.append(-num)

                elif sign == '*':
                    stack.append(stack.pop() * num)

                elif sign == '/':
                    stack.append(int(stack.pop() / num))

                sign = ch
                num = 0

        return sum(stack)
