class Solution:
    def calPoints(self, operations: List[str]) -> int:
        
        stack = []
        for opr in operations:
            if opr == "C":
                stack.pop()
            elif opr == "D":
                stack.append(2 * stack[-1])
            elif opr == "+":
                stack.append(stack[-1] + stack[-2])
            else:
                stack.append(int(opr))
        return sum(stack)
