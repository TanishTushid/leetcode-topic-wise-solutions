# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def swapNodes(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:
        fist, second, temp = head, head, head 
        #move pointer from start'
        for i in range(k-1):
            temp = temp.next
        first = temp
        #move pointer to end 
        while temp.next:
            temp = temp.next
            second = second.next 
        #swap the values
        first.val, second.val = second.val, first.val
        return head 
