from collections import deque
from typing import List


class Solution:
    def maximumSafenessFactor(self, grid: List[List[int]]) -> int:
        n = len(grid)

        # -------------------------------
        # Step 1: Multi-source BFS
        # Compute distance to nearest thief
        # -------------------------------
        distance = [[-1] * n for _ in range(n)]
        queue = deque()

        for r in range(n):
            for c in range(n):
                if grid[r][c] == 1:
                    queue.append((r, c))
                    distance[r][c] = 0

        directions = [(0, 1), (0, -1), (1, 0), (-1, 0)]

        while queue:
            r, c = queue.popleft()

            for dr, dc in directions:
                nr = r + dr
                nc = c + dc

                if (
                    0 <= nr < n
                    and 0 <= nc < n
                    and distance[nr][nc] == -1
                ):
                    distance[nr][nc] = distance[r][c] + 1
                    queue.append((nr, nc))

        # -------------------------------
        # Step 2: Check if a path exists
        # with safeness >= limit
        # -------------------------------
        def can_reach(limit):

            # Start cell is not safe enough
            if distance[0][0] < limit:
                return False

            q = deque([(0, 0)])
            visited = {(0, 0)}

            while q:
                r, c = q.popleft()

                if (r, c) == (n - 1, n - 1):
                    return True

                for dr, dc in directions:
                    nr = r + dr
                    nc = c + dc

                    if (
                        0 <= nr < n
                        and 0 <= nc < n
                        and (nr, nc) not in visited
                        and distance[nr][nc] >= limit
                    ):
                        visited.add((nr, nc))
                        q.append((nr, nc))

            return False

        # -------------------------------
        # Step 3: Binary Search
        # -------------------------------
        left = 0
        right = max(max(row) for row in distance)
        answer = 0

        while left <= right:

            mid = (left + right) // 2

            if can_reach(mid):
                answer = mid
                left = mid + 1
            else:
                right = mid - 1

        return answer
