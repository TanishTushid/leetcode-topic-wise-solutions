class Solution:
    def highestPeak(self, isWater: List[List[int]]) -> List[List[int]]:
        
        rows = len(isWater)
        cols = len(isWater[0])
        queue = deque()
        visited = ()
        height = [[-1] * cols  for _ in range(rows)]
        for i in range(rows):
            for j in range(cols):
                if isWater[i][j] == 1:
                    queue.append((i, j))
                    height[i][j] = 0
        direction = ((1, 0), (-1, 0), (0, 1), (0, -1))
        while queue:
            r, c = queue.popleft()
            for dr, dc in direction:
                nr = dr +r
                nc = dc +c

                if 0 <= nr < rows and 0 <= nc < cols and height[nr][nc] == -1:
                    height[nr][nc] = height[r][c] +1
                    queue.append((nr, nc))
        return height 
