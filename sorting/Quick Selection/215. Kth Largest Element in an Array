class Solution:
    def findKthLargest(self, nums: List[int], k: int) -> int:

        k = len(nums) - k
        l, r = 0, len(nums) - 1

        while l <= r:

            pivot_index = random.randint(l, r)
            nums[pivot_index], nums[r] = nums[r], nums[pivot_index]

            pivot = nums[r]
            i = l

            for j in range(l, r):
                if nums[j] <= pivot:
                    nums[i], nums[j] = nums[j], nums[i]
                    i += 1

            nums[i], nums[r] = nums[r], nums[i]

            if i == k:
                return nums[i]

            elif i < k:
                l = i + 1

            else:
                r = i - 1


