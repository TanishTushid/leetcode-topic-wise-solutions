class Solution:
    def sortPeople(self, names: List[str], heights: List[int]) -> List[str]:

        people = [[heights[i], names[i]] for i in range(len(names))]

        def quick_sort(low, high):
            if low >= high:
                return

            pivot = people[high]
            i = low

            for j in range(low, high):

                # Descending order by height
                if people[j][0] > pivot[0]:
                    people[i], people[j] = people[j], people[i]
                    i += 1

            people[i], people[high] = people[high], people[i]

            quick_sort(low, i - 1)
            quick_sort(i + 1, high)

        quick_sort(0, len(people) - 1)

        return [name for height, name in people]
