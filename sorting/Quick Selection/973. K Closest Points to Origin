from typing import List
import random
class Solution:
    def kClosest(self, points: List[List[int]], k: int) -> List[List[int]]:

        def distance(points):
            x,y = points
            return x*x + y*y
        def partion(left, right):
            pivot = distance(points[right]) #lomuto partition
            i = left
            for j in range(left, right):
                if distance(points[j]) <= pivot:
                    points[i], points[j] = points[j], points[i]
                    i +=1
            points[i], points[right] = points[right], points[i]
            return i
        left = 0
        right = len(points) -1
        while True:
            pivot_idx = partion(left, right)
            if pivot_idx == k -1:
                return points[:k]
            elif pivot_idx < k -1:
                left = pivot_idx +1
            else:
                right = pivot_idx -1
