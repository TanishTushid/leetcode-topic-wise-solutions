class Solution:
    def moveZeroes(self, nums: List[int]) -> None:

        n = len(nums)
        for i in range(n - 1):
            swapped = False
            for j in range(n - 1 - i):
                if nums[j] == 0 and nums[j + 1] != 0:
                    nums[j], nums[j + 1] = nums[j + 1], nums[j]
                    swapped = True
            if not swapped:
                break
