class Solution:
    def sortedSquares(self, nums: List[int]) -> List[int]:

        nums = [x * x for x in nums]

        n = len(nums)

        for i in range(n - 1):
            swapped = False

            for j in range(n - 1 - i):

                if nums[j] > nums[j + 1]:
                    nums[j], nums[j + 1] = nums[j + 1], nums[j]
                    swapped = True

            if not swapped:
                break

        return nums
