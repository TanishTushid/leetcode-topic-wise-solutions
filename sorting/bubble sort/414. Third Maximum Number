class Solution:
    def thirdMax(self, nums: List[int]) -> int:
        nums = list(set(nums))
        n = len(nums)
        for i in range(n -1):
            swapped = False
            for j in range(n -1 -i):
                if nums[j] > nums[j +1]:
                    #swap 
                    nums[j], nums[j +1] = nums[j +1], nums[j]
                    swapped = True
            if not swapped:
                break
        return nums[n - 3] if n >= 3 else nums[n - 1]
