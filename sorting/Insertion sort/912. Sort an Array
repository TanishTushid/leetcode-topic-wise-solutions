class Solution:
    def sortArray(self, nums: List[int]) -> List[int]:
        n = len(nums) # length of the array 
        for i in range(1, n): #start at first index to nth
            key = nums[i] #store current element 
            j = i -1  #previous element
            while j >= 0 and nums[j] > key: #insert 
                #swap 
                nums[j +1] = nums[j]
                j -=1 #move left 
            nums[j +1] = key #move current 
        return nums
