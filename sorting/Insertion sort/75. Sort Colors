class Solution:
    def sortColors(self, nums: List[int]) -> None:
        """
        Do not return anything, modify nums in-place instead.
        """

        n = len(nums) #length of the array
        for i in range(1, n): #start from 1 index to nth index
            key = nums[i] #curr element 
            j = i -1    #previous element
            while j >= 0 and nums[j] > key: #insert 
                nums[j +1] = nums[j] #swap 
                j -=1 # move prev
            nums[j +1] = key #move curr
        return nums
