class Solution:
    def merge(self, nums1: List[int], m: int, nums2: List[int], n: int) -> None:
        """
        Do not return anything, modify nums1 in-place instead.
        """
        #copy nums2 into nums1
        for i in range(n):
            nums1[m +i] = nums2[i]
        #length m +n
        length = m +n
        for i in range(1, length):
            key = nums1[i]
            j = i -1
            while j >= 0 and nums1[j] > key:
                nums1[j +1] = nums1[j]
                j -= 1
            nums1[j +1] = key
        return nums1
