class Solution:
    def sortedSquares(self, nums: List[int]) -> List[int]:

        nums = [x * x for x in nums]
        n = len(nums)
        for i in range(n -1):
            min_idx = i
            for j in range(i +1, n):
                if abs(nums[j]) < abs(nums[min_idx]):
                    min_idx = j
            nums[i], nums[min_idx] = nums[min_idx], nums[i]
        return nums
