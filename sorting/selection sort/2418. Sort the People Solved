class Solution:
    def sortPeople(self, names: List[str], heights: List[int]) -> List[str]:

        people = [[heights[i], names[i]] for i in range(len(names))]

        n = len(people)
        for i in range(n -1):
            min_idx = i
            for j in range(i +1, n):
                if people[j][0] > people[min_idx][0]:
                    min_idx = j
            people[i], people[min_idx] = people[min_idx], people[i]
        return [name for heights, name in people]
